<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>{{stack_title}}</title>

  <link rel="stylesheet" href="/assets/app.css?v=dev3" />
  <script src="/assets/lucide.min.js" defer></script>
</head>
<body class="min-h-screen bg-neutral-950 text-white antialiased">
  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-neutral-950/70 backdrop-blur">
    <div class="mx-auto max-w-6xl px-4 h-16 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2 font-semibold">
        <span class="inline-block h-6 w-6" data-lucide="layers"></span>
        <span>CreditRoute</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="#features" class="hover:text-lime-300/90">Features</a>
        <a href="#results" class="hover:text-lime-300/90">Results</a>
        <a href="#plans" class="hover:text-lime-300/90">Plans</a>
        <a href="#pricing" class="hover:text-lime-300/90">Pricing</a>
        <a href="#faq" class="hover:text-lime-300/90">FAQ</a>
        <a href="#build" class="hover:text-lime-300/90">Build</a>
      </nav>
      <a href="#pricing" class="inline-flex items-center gap-2 rounded-xl border border-white/10 px-3 py-1.5 text-sm hover:bg-white/5">
        <span>Start My Credit Route</span>
        <span class="h-4 w-4" data-lucide="arrow-right"></span>
      </a>
    </div>
  </header>

  <main id="home">
    <section id="hero" class="section pt-32 md:pt-40 pb-24">
      <div class="mx-auto max-w-6xl px-4 grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight">
            Credit-building plans that <span class="text-lime-300">actually ship</span>
          </h1>
          <p class="mt-4 text-lg text-white/80 max-w-prose">
            Choose Foundation, Growth, Accelerator, or Elite. We assemble a verified app stack and a step-by-step guide tailored to you.
          </p>
          <div class="mt-8 flex gap-3">
            <a href="#plans" class="rounded-2xl bg-lime-400/90 text-neutral-900 font-semibold px-5 py-3 hover:bg-lime-300">Explore plans</a>
            <a href="#results" class="rounded-2xl border border-white/10 px-5 py-3 hover:bg-white/5">See results</a>
          </div>
        </div>
        <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-white/5 to-white/0 p-6">
          <div class="aspect-video rounded-2xl border border-white/10 bg-black/40 grid place-items-center text-white/60">
            <span class="h-8 w-8" data-lucide="line-chart"></span>
            <span class="sr-only">Preview</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/10 py-10 text-center text-white/60">
    <div class="mx-auto max-w-6xl px-4">
      <p>&copy; {{year}} CreditRoute. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>